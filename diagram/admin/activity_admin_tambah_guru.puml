@startuml
skinparam linetype ortho
skinparam DefaultFontName Arial
skinparam shadowing false

skinparam Activity {
    BackgroundColor #FFFFCC
    BorderColor #B22222
    StartColor #B22222
    EndColor #B22222
    ArrowColor #B22222
}
skinparam ArrowColor #B22222

mainframe act Admin Menambah Data Guru

|Admin|
start
:Pilih Menu "Data Guru";
:Klik Tombol "Tambah Guru";
:Isi Form Data Guru\n(NIP, Nama, dll);
:Klik "Simpan";
|Sistem|
:Validasi Input;
if (Valid?) then (Ya)
    :Simpan ke Database;
    :Tampilkan Pesan Berhasil;
else (Tidak)
    :Tampilkan Pesan Error;
endif
|Admin|
:Lihat Data Tersimpan;
stop
@enduml
