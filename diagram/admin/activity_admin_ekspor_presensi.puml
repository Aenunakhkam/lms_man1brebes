@startuml
skinparam linetype ortho
skinparam DefaultFontName Arial
skinparam shadowing false

skinparam Activity {
    BackgroundColor #FFFFCC
    BorderColor #B22222
    StartColor #B22222
    EndColor #B22222
    ArrowColor #B22222
}
skinparam ArrowColor #B22222

mainframe act Admin Ekspor Data Presensi

|Admin|
start
:Buka Menu "Laporan Presensi";
:Pilih Kelas dan Rentang Tanggal;
:Tampilkan Rekap Presensi;
:Klik "Ekspor Presensi";
:Pilih Format (Excel / PDF);
|Sistem|
:Query Data Presensi dari Database;
:Generate File sesuai Format;
:Kirim File ke Browser;
|Admin|
:Unduh File ke Perangkat Lokal;
stop
@enduml
