@startuml
skinparam linetype ortho
skinparam DefaultFontName Arial
skinparam shadowing false

skinparam Activity {
    BackgroundColor #FFFFCC
    BorderColor #B22222
    StartColor #B22222
    EndColor #B22222
    ArrowColor #B22222
}
skinparam ArrowColor #B22222

mainframe act Kelola Data Pengguna (Reset Password)

|Admin|
start
:Buka Menu "Data Pengguna";
:Tampilkan Daftar Pengguna (Siswa/Guru/Admin);
:Cari Pengguna Spesifik;
:Klik tombol "Reset Password";
:Konfirmasi Reset Password;
|Sistem|
:Validasi Permintaan;
:Update Password ke Default;
:Tampilkan Notifikasi Sukses;
|Admin|
:Melihat Notifikasi;
stop
@enduml
