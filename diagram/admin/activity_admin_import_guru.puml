@startuml
skinparam linetype ortho
skinparam DefaultFontName Arial
skinparam shadowing false

skinparam Activity {
    BackgroundColor #FFFFCC
    BorderColor #B22222
    StartColor #B22222
    EndColor #B22222
    ArrowColor #B22222
}
skinparam ArrowColor #B22222

mainframe act Admin Import Data Guru

|Admin|
start
:Buka Menu "Data Guru";
:Klik Tombol "Import Data";
:Unduh Template Excel (Opsional);
:Pilih File Excel dari Perangkat Lokal;
:Klik "Upload & Proses";
|Sistem|
:Membaca Isi File Excel;
:Validasi Format Kolom (NIP, Nama, dll);
if (Data Valid?) then (Ya)
    :Simpan Massal ke Database;
    :Tampilkan Pesan Berhasil;
else (Tidak)
    :Batalkan Proses Simpan;
    :Tampilkan Pesan Error (Terdapat Data Tidak Valid);
endif
|Admin|
:Melihat Hasil Import di Tabel Guru;
stop
@enduml
